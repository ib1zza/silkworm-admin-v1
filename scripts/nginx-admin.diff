--- /etc/nginx/sites-available/silkworm
+++ /etc/nginx/sites-available/silkworm
@@
     client_max_body_size 20M;
 
     location /uploads/ {
         alias /var/www/silkworm/wwwroot/images/;
         expires 30d;
@@
     root /var/www/silkworm-frontend-v1/current;
     index index.html;
 
     location /api/ {
         proxy_pass         http://127.0.0.1:5000;
@@
         proxy_buffering on;
         proxy_buffer_size 8k;
         proxy_buffers 8 8k;
     }
 
+    location = /admin {
+        return 301 /admin/;
+    }
+
+    location ^~ /admin/ {
+        alias /var/www/silkworm-frontend-v1/shared/admin/current/;
+        index index.html;
+        try_files $uri $uri/ /admin/index.html;
+    }
+
     location / {
         try_files $uri $uri/ /index.html;
     }
 }
